{
	"files": {
		"includes": ["app/**", "!app/components.d.ts"],
		"experimentalScannerIgnores": ["**/.nuxt", "**/.output", "**/.agents"]
	},
	"linter": {
		"rules": {
			"correctness": {
				"noUnusedVariables": "warn",
				"noVueDuplicateKeys": "off"
			},
			"complexity": {
				"noBannedTypes": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noRedeclare": "off"
			}
		}
	}
}
